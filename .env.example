# ============================================================
# UCMAS Summer Camp 2026 — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# --- Google OAuth (for admin login) ---
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# --- Google Sheets (Apps Script Web App URL) ---
GOOGLE_SHEETS_WEBAPP_URL=https://script.google.com/macros/s/REPLACE/exec

# --- Telegram Bot (optional: real-time lead notifications) ---
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# --- Facebook Pixel (client-side) ---
NEXT_PUBLIC_FB_PIXEL_ID=2007191976465252

# --- Google Ads (client-side) ---
NEXT_PUBLIC_GA_CONVERSION_ID=AW-359081376
NEXT_PUBLIC_GA_CONVERSION_LABEL=V0D_CLKy4a8ZEKDLnKsB

# --- App URLs ---
NEXT_PUBLIC_SITE_URL=https://traihe.ucmasvietnam.com
NEXT_PUBLIC_ADMIN_URL=https://traihe.ucmasvietnam.com/admin

# --- Admin Access (comma-separated emails allowed to access /admin) ---
ADMIN_ALLOWED_EMAILS=yen@ucmasvietnam.com,admin@ucmasvietnam.com
